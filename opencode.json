{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "lightbridge": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LightBridge Server",
      "options": {
        "baseURL": "{env:LIGHTBRIDGE_BASE_URL}",
        "headers": {
          "Authorization": "Bearer {env:LIGHTBRIDGE_API_KEY}"
        }
      },
      "models": {
        "gemini-3-flash": {
          "name": "Gemini 3 Flash"
        },
        "glm-5": {
          "name": "GLM-5"
        }
      }
    }
  },
  "mode": {
    "review": {
      "prompt": "{file:.opencode/review-rules.md}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true,
        "read": true,
        "grep": true,
        "glob": true
      }
    }
  }
}